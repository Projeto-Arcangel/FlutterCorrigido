rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return isAuth() && userRole() == 'teacher';
    }

    function classroomDoc(classroomId) {
      return get(/databases/$(database)/documents/Classrooms/$(classroomId));
    }

    function isClassroomTeacher(classroomId) {
      return isAuth() && classroomDoc(classroomId).data.teacherId == request.auth.uid;
    }

    function isClassroomMember(classroomId) {
      return isAuth()
        && (classroomDoc(classroomId).data.teacherId == request.auth.uid
            || request.auth.uid in classroomDoc(classroomId).data.studentIds);
    }

    // ─── Users ────────────────────────────────────────────────
    // Cada usuário só acessa/modifica seu próprio doc.
    // setRole, createProfileIfAbsent, addXp, addGold, advancePhase
    match /Users/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ─── Phase (top-level, lições pré-seed + fases de classroom) ──
    match /Phase/{phaseId} {
      allow read: if isAuth();
      // Somente leitura — conteúdo pré-seed.
      // Fases do professor vão para Classrooms/{id}/phases.
      allow write: if false;
    }

    // ─── Questions (top-level) ────────────────────────────────
    match /Questions/{questionId} {
      allow read: if isAuth();
      // Somente leitura — conteúdo pré-seed.
      // Questões do professor vão para Classrooms/{id}/phases/{phaseId}/questions.
      allow write: if false;
    }

    // Subcoleção legacy de multiple_choice
    match /Questions/{parent}/multiple_choice/{document} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /Classrooms/{document} {
    allow read: if request.auth != null;
    allow create: if request.auth != null
    && request.resource.data.teacherId == request.auth.uid;
    allow update, delete: if request.auth != null
    && resource.data.teacherId == request.auth.uid;
}

    match /{path=**}/multiple_choice/{document} {
      allow read: if request.auth != null;
    }

    match /Users/{document} {
      allow create: if request.auth.uid == document;
      allow read:   if request.auth.uid == document;
      allow write:  if request.auth.uid == document;
      allow delete: if request.auth.uid == document;
    }

    match /{document=**} {
      allow read, write: if request.auth.token.email.matches("firebase@flutterflow.io");
    }
  }
}