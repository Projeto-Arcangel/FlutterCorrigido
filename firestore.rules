rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return isAuth() && userRole() == 'teacher';
    }

    function classroomDoc(classroomId) {
      return get(/databases/$(database)/documents/Classrooms/$(classroomId));
    }

    function isClassroomTeacher(classroomId) {
      return isAuth() && classroomDoc(classroomId).data.teacherId == request.auth.uid;
    }

    function isClassroomMember(classroomId) {
      return isAuth()
        && (classroomDoc(classroomId).data.teacherId == request.auth.uid
            || request.auth.uid in classroomDoc(classroomId).data.studentIds);
    }

    // ─── Users ────────────────────────────────────────────────
    // Cada usuário só acessa/modifica seu próprio doc.
    match /Users/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ─── Phase (top-level, lições pré-seed) ───────────────────
    match /Phase/{phaseId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── Questions (top-level) ────────────────────────────────
    match /Questions/{questionId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Subcoleção legacy de multiple_choice
    match /Questions/{parent}/multiple_choice/{document} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── Classrooms ──────────────────────────────────────────
    match /Classrooms/{classroomId} {
      // Qualquer autenticado pode ler (necessário para buscar por código)
      allow read: if isAuth();

      // Somente o professor pode criar (teacherId deve ser o próprio uid)
      allow create: if isAuth()
        && request.resource.data.teacherId == request.auth.uid;

      // Professor pode atualizar/deletar qualquer campo.
      // Aluno autenticado pode atualizar SOMENTE o campo studentIds
      // (para entrar/sair da sala via arrayUnion/arrayRemove).
      allow update: if isAuth()
        && (
          // Professor — pode tudo
          resource.data.teacherId == request.auth.uid
          // Aluno — só pode alterar studentIds, nada mais
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
          )
        );

      allow delete: if isAuth()
        && resource.data.teacherId == request.auth.uid;

      // ── Subcoleção: questions (questões diretas da sala) ────
      match /questions/{questionId} {
        allow read: if isAuth();
        allow write: if isClassroomTeacher(classroomId);
      }

      // ── Subcoleção: results (resultados dos alunos) ────────
      match /results/{resultId} {
        // Professor e membros podem ler resultados
        allow read: if isClassroomMember(classroomId);
        // Aluno pode criar/atualizar apenas o próprio resultado
        allow create, update: if isAuth()
          && resultId == request.auth.uid;
        allow delete: if isClassroomTeacher(classroomId);
      }

      // ── Subcoleção: phases (fases/quizzes criados pelo professor) ─
      match /phases/{phaseId} {
        allow read: if isClassroomMember(classroomId);
        allow write: if isClassroomTeacher(classroomId);

        // Questões dentro de uma fase
        match /questions/{questionId} {
          allow read: if isClassroomMember(classroomId);
          allow write: if isClassroomTeacher(classroomId);
        }
      }
    }

    // ─── Wildcard para multiple_choice (collection group queries) ─
    match /{path=**}/multiple_choice/{document} {
      allow read: if request.auth != null;
    }

    // ─── FlutterFlow admin ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth.token.email.matches("firebase@flutterflow.io");
    }
  }
}